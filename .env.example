# Copy this file to .env and fill in the values for local development.
# On Render, these are set via the dashboard or render.yaml envVars.

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/paintkart?schema=public"

# JWT signing secret — use a long random string in production
JWT_SECRET="change-me-to-a-long-random-secret"

# Admin dashboard passcode
ADMIN_PASSCODE="admin123"

# Server port (Render sets this automatically)
PORT=3000

# Comma-separated allowed CORS origins
# Local: http://localhost:8081
# Production: https://your-app.com
CORS_ORIGIN="http://localhost:8081"

# local | s3
STORAGE_DRIVER="local"

# Public base URL used when generating upload URLs
PUBLIC_BASE_URL="http://localhost:3000"

# Required when STORAGE_DRIVER=s3
AWS_REGION="ap-south-1"
AWS_S3_BUCKET="paintcart-uploads"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# Optional S3 settings
# Use a CloudFront/custom asset domain here when available.
AWS_S3_PUBLIC_BASE_URL=""
AWS_S3_PUBLIC_READ_ACL="false"
AWS_S3_ENDPOINT=""
AWS_S3_FORCE_PATH_STYLE="false"

# development | production
NODE_ENV="development"
